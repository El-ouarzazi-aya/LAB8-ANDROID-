<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ══ EN-TÊTE ══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ASYNC LAB"
            android:textColor="#00E5FF"
            android:textSize="38sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Threads  ·  AsyncTask  ·  UI Thread"
            android:textColor="#374151"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="28dp"/>

        <!-- ══ CARTE STATUT ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#0F172A"
            app:cardCornerRadius="14dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● SYSTEM STATUS"
                    android:textColor="#00E5FF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.25"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="> Système prêt. En attente d'une commande..."
                    android:textColor="#CBD5E1"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:minLines="2"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ CARTE PROGRESSION ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#0F172A"
            app:cardCornerRadius="14dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="PROGRESSION"
                        android:textColor="#00E5FF"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.25"/>

                    <TextView
                        android:id="@+id/txtPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 %"
                        android:textColor="#00E5FF"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#00E5FF"
                    android:progressBackgroundTint="#1E293B"
                    android:visibility="invisible"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ CARTE IMAGE ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="#0F172A"
            app:cardCornerRadius="14dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="IMAGE BUFFER"
                    android:textColor="#00E5FF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.25"
                    android:layout_marginBottom="14dp"/>

                <ImageView
                    android:id="@+id/img"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="Aperçu image chargée"
                    android:scaleType="centerCrop"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ BOUTON 1 — Thread ══ -->
        <Button
            android:id="@+id/btnLoadThread"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="[ CHARGER IMAGE ]   Thread →"
            android:textColor="#00E5FF"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:backgroundTint="#0F172A"
            app:strokeColor="#00E5FF"
            app:strokeWidth="2dp"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- ══ BOUTON 2 — AsyncTask ══ -->
        <Button
            android:id="@+id/btnCalcAsync"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="[ CALCUL LOURD ]   AsyncTask →"
            android:textColor="#A78BFA"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:backgroundTint="#0F172A"
            app:strokeColor="#A78BFA"
            app:strokeWidth="2dp"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- ══ BOUTON 3 — Toast / Ping UI ══ -->
        <Button
            android:id="@+id/btnToast"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="[ PING UI ]   Toast →"
            android:textColor="#34D399"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:backgroundTint="#0F172A"
            app:strokeColor="#34D399"
            app:strokeWidth="2dp"
            android:layout_marginBottom="28dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- ══ FOOTER ══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="// UI THREAD NEVER BLOCKED //"
            android:textColor="#1E293B"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>